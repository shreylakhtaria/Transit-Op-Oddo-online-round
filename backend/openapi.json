    "/api/users": {
      "get": {
        "description": "Lists all users with their role. Restricted to Fleet Managers. The password hash is never returned.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "required": true,
            "type": "string",
            "description": "Bearer <access token> of a Fleet Manager"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "example": "3f2504e0-4f89-11d3-9a0c-0305e82c3301"
                  },
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "role": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer"
                      },
                      "name": {
                        "type": "string"
                      }
                    }
                  },
                  "createdAt": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden - restricted to Fleet Managers"
          }
        }
      }
    },
    "/api/users/{id}/role": {
      "patch": {
        "description": "Reassigns a user's role. Restricted to Fleet Managers. Returns the updated user in the same shape as GET /api/users (never the password hash).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "User UUID"
          },
          {
            "name": "authorization",
            "in": "header",
            "required": true,
            "type": "string",
            "description": "Bearer <access token> of a Fleet Manager"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "roleName"
              ],
              "properties": {
                "roleName": {
                  "type": "string",
                  "enum": [
                    "Fleet Manager",
                    "Driver",
                    "Safety Officer",
                    "Financial Analyst"
                  ]
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request - unknown role"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden - restricted to Fleet Managers"
          },
          "404": {
            "description": "Not Found - unknown user"
          }
        }
      }
    }
  }
