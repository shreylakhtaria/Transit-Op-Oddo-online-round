    "/api/vehicles": {
      "get": {
        "description": "Lists vehicles. Pagination is opt-in: omit both `page` and `limit` to receive the bare array; supply either one to receive the { data, total, page, limit } envelope.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "type",
            "in": "query",
            "type": "string"
          },
          {
            "name": "status",
            "in": "query",
            "type": "string"
          },
          {
            "name": "page",
            "in": "query",
            "type": "integer",
            "minimum": 1,
            "default": 1,
            "description": "Opt-in pagination. 1-based page number; defaults to 1 when only `limit` is given."
          },
          {
            "name": "limit",
            "in": "query",
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 10,
            "description": "Opt-in pagination. Page size (1-100); defaults to 10 when only `page` is given."
          }
        ],
        "responses": {
          "200": {
            "description": "OK - a bare array, or the { data, total, page, limit } envelope when `page` or `limit` is supplied"
          },
          "400": {
            "description": "Bad Request - invalid `page` or `limit`"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "description": "",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
