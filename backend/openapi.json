    "/api/expenses/fuel": {
      "get": {
        "description": "Lists fuel logs, newest first (date DESC, then id DESC), each with its vehicle attached. Readable by any authenticated role.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "vehicleId",
            "in": "query",
            "type": "integer",
            "description": "Optional. Restricts the result to fuel logs for this vehicle."
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer"
                  },
                  "vehicleId": {
                    "type": "integer"
                  },
                  "tripId": {
                    "type": "integer"
                  },
                  "liters": {
                    "type": "number"
                  },
                  "cost": {
                    "type": "number"
                  },
                  "date": {
                    "type": "string",
                    "example": "2026-07-12"
                  },
                  "vehicle": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer"
                      },
                      "registrationNumber": {
                        "type": "string"
                      },
                      "model": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
