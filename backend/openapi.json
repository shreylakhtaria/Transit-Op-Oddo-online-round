  "paths": {
    "/api/auth/register": {
      "post": {
        "description": "Creates a user account with the given role. Requires a Fleet Manager bearer token: the endpoint accepts a client-supplied roleName (including 'Fleet Manager'), so it is not reachable anonymously. The initial accounts are created by the database seeders.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "required": true,
            "type": "string",
            "description": "Bearer <access token> of a Fleet Manager"
          },
          {
            "name": "body",
            "in": "body",
            "schema": {
              "type": "object",
              "required": [
                "name",
                "email",
                "password",
                "roleName"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Jane Doe"
                },
                "email": {
                  "type": "string",
                  "example": "jane@transitops.com"
                },
                "password": {
                  "type": "string",
                  "example": "password123"
                },
                "roleName": {
                  "type": "string",
                  "enum": [
                    "Fleet Manager",
                    "Driver",
                    "Safety Officer",
                    "Financial Analyst"
                  ]
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized - authentication is required"
          },
          "403": {
            "description": "Forbidden - restricted to Fleet Managers"
          }
        }
      }
    },
