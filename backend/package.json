{
  "name": "transit-ops-backend",
  "version": "1.0.0",
  "description": "Smart Transport Operations Platform API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:create": "sequelize-cli db:create",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all",
    "db:migrate:undo": "sequelize-cli db:migrate:undo:all",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit",
    "test:verbose": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit --verbose"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.10.1",
    "nodemailer": "^9.0.3",
    "sequelize": "^6.37.3",
    "sqlite3": "^6.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "jest": "^30.4.2",
    "nodemon": "^3.1.4",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.2.2",
    "swagger-autogen": "^2.23.7"
  }
}
