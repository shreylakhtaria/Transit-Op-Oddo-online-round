# TransitOps backend — copy to .env and fill in. NEVER commit the real .env.
NODE_ENV=development
PORT=8000

# Database (local MySQL, or a managed MySQL like TiDB Cloud / Aiven — set DB_SSL=true for managed)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=transit_ops
DB_USER=root
DB_PASS=
DB_SSL=false

# Any random string ≥8 chars. Generate one: openssl rand -hex 32
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Demo mode: when true, POST /auth/login also returns the OTP in the response so shared
# accounts can log in without inbox access. Leave false for any real deployment.
EXPOSE_OTP=false

# SMTP (optional). Without it, the OTP is logged to the server console instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@transitops.com
